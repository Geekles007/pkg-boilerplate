{
  "name": "pkg-boilerplate",
  "version": "0.0.0",
  "private": true,
  "description": "Boilerplate monorepo for shadcn-style, registry-as-code packages (no database, no backend).",
  "license": "MIT",
  "author": "Geekles007",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "registry:build": "turbo run build --filter=@pkg-boilerplate/registry",
    "rename": "node scripts/rename.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
